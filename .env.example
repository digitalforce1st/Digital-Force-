# ═══════════════════════════════════════════════════════════
# Digital Force — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git
# ═══════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────
APP_NAME=Digital Force
ENVIRONMENT=development
DEBUG=true
BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ── Security (generate strong values for production) ─────
JWT_SECRET_KEY=CHANGE-THIS-TO-A-256-BIT-RANDOM-STRING
ENCRYPTION_KEY=CHANGE-THIS-32-BYTE-KEY-IN-PROD!!

# ── Database ─────────────────────────────────────────────
# SQLite (development default — no setup needed)
DATABASE_URL=sqlite+aiosqlite:///./digitalforce.db

# PostgreSQL (production recommended)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/digitalforce

# ── Redis (for Celery task queue) ────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── AI — Groq (Primary LLM Ecosystem, 9 Model Cascade) ────────
# Get keys at: https://console.groq.com
GROQ_API_KEY_1=
GROQ_API_KEY_2=
GROQ_API_KEY_3=

GROQ_PRIMARY_MODEL=llama-3.3-70b-versatile
GROQ_SECONDARY_MODEL=mixtral-8x7b-32768
GROQ_FALLBACK_MODEL=groq/compound

# ── Vector DB — Qdrant ────────────────────────────────────
# Cloud (recommended): https://cloud.qdrant.io
QDRANT_URL=
QDRANT_API_KEY=

# Local fallback (no setup needed, data stored locally)
QDRANT_LOCAL_PATH=./qdrant_data
QDRANT_KNOWLEDGE_COLLECTION=df-knowledge
QDRANT_BRAND_COLLECTION=df-brand
QDRANT_MEDIA_COLLECTION=df-media

# ── Publishing — Buffer API ───────────────────────────────
# Get token at: https://buffer.com/developers/api
# Covers: LinkedIn, X/Twitter, TikTok, Instagram, YouTube, Pinterest, Threads
BUFFER_ACCESS_TOKEN=

# ── Publishing — Facebook Graph API ──────────────────────
# Get at: https://developers.facebook.com
FACEBOOK_PAGE_ID=
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_API_VERSION=v21.0

# ── Image Generation ──────────────────────────────────────
# DALL-E 3 via OpenAI key above
# Stability AI (alternative)
STABILITY_API_KEY=

# ── Media Storage ─────────────────────────────────────────
STORAGE_BACKEND=local
MEDIA_UPLOAD_DIR=./media/uploads
MEDIA_PROCESSED_DIR=./media/processed

# S3/R2 (uncomment for cloud storage)
# STORAGE_BACKEND=s3
# S3_BUCKET=your-bucket
# S3_REGION=us-east-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# ── Email Notifications ───────────────────────────────────
# For approval emails. Gmail example below:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=Digital Force
SMTP_FROM_EMAIL=your@gmail.com

# ── SkillForge — E2B Sandbox ──────────────────────────────
# Get key at: https://e2b.dev
# Leave empty to use local syntax-check only (safe fallback)
E2B_API_KEY=

# ── Web Research ──────────────────────────────────────────
# Tavily Search API (for Researcher agent)
# Get key at: https://tavily.com
TAVILY_API_KEY=

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
